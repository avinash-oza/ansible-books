#!/bin/sh
#
# This shell script if placed in /etc/apcupsd
# will be called by /etc/apcupsd/apccontrol when the    
# UPS goes back on to the mains after a power failure.
# We send an email message to root to notify him.
#

export HOSTNAME=`hostname`
export AWS_ACCESS_KEY_ID={{ vault_aws_keys['apcupsd'].key_id }}
export AWS_SECRET_ACCESS_KEY={{ vault_aws_keys['apcupsd'].access_key }}
export TOPIC_ARN={{ vault_nagios_alert_sns_endpoint }}
export AWS_DEFAULT_REGION={{ vault_aws_default_region }}

export MSG="$HOSTNAME Power has returned"
#
(
   echo "Subject: $MSG"
   echo " "
   echo "$MSG"
   echo " "
   /sbin/apcaccess status
) 

aws sns publish --topic-arn ${TOPIC_ARN} --message "${MSG}" > /dev/null
